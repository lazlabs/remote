{
  "name": "Movie Room Remote",
  "short_name": "Movie Room",
  "description": "Smart home theater remote — LAZLAB Creations",
  "start_url": "./theater-remote.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#0C0C12",
  "theme_color": "#0C0C12",
  "categories": ["entertainment", "utilities"],
  "lang": "en-US",
  "icons": [
    {
      "src": "./icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "./icon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "./icon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Casual TV",
      "short_name": "Casual",
      "description": "Switch to Casual TV mode",
      "url": "./theater-remote.html?mode=casual",
      "icons": [{ "src": "./icon.svg", "sizes": "512x512" }]
    },
    {
      "name": "Movie Night",
      "short_name": "Movies",
      "description": "Switch to Movie Night mode",
      "url": "./theater-remote.html?mode=theater",
      "icons": [{ "src": "./icon.svg", "sizes": "512x512" }]
    }
  ],
  "prefer_related_applications": false
}
